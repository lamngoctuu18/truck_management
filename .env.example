# Sao chép file này thành .env rồi điền giá trị thật (đặc biệt DB_PASSWORD).
# .env chứa mật khẩu nên KHÔNG được commit lên git.

# ==== Database (PostgreSQL localhost) ====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=vehicle_management

# ==== Nguồn video ====
# Có thể là: đường dẫn file (data/videos/xxx.mp4), số webcam (0), hoặc URL RTSP
VIDEO_SOURCE=0
CAMERA_TYPE=GATE
CAMERA_NAME=Cong chinh

# ==== Xử lý AI ====
FPS_PROCESS=10
VEHICLE_MODEL=models/yolov8n.pt
PLATE_MODEL=models/license_plate_detector.pt
DEVICE=auto
VEHICLE_CONF=0.35
PLATE_CONF=0.30
OCR_MIN_CONF=0.65
LPR_MIN_BBOX_RATIO=0.02
LPR_GOOD_CONF=0.85
LPR_MAX_ATTEMPTS=8
LPR_INTERVAL_SEC=0.35
LPR_MIN_VOTES=2
LPR_TRACK_TTL_SEC=6
DEDUP_SECONDS=45
DWELL_THRESHOLD_SEC=1800
STUCK_IN_YARD_HOURS=4
RECONCILE_TIME_WINDOW_MIN=30
COLLECT_TRAINING_DATA=false

# ==== Chế độ demo đếm xe ====
DEMO_MODE=true
VIDEO_LOOP=false
PLAYBACK_REALTIME=true
ENABLE_PLATE_RECOGNITION=false
ENABLE_LOAD_CLASSIFICATION=false
ENABLE_PLATE_DEDUP=false
ENABLE_EVIDENCE_CLIPS=false
ENABLE_ANALYTICS_ALERTS=false
COUNT_CLASSES=car,bus,truck
LINE_HYSTERESIS_PX=6

# ==== Vạch ảo (line-crossing), toạ độ tỉ lệ 0..1 ====
LINE_X1=0.15
LINE_Y1=0.5
LINE_X2=0.85
LINE_Y2=0.5
IN_DIRECTION=up

# ==== Web ====
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ==== Lưu trữ ====
SNAPSHOT_DIR=data/snapshots
CLIP_DIR=data/clips
